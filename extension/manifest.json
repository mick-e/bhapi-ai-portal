{
  "manifest_version": 3,
  "name": "Bhapi AI Safety Monitor",
  "version": "1.0.0",
  "description": "Monitor AI platform usage for safety compliance. Part of the Bhapi AI Safety Portal.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://x.com/i/grok*",
    "https://character.ai/*",
    "https://beta.character.ai/*",
    "https://web.replika.com/*",
    "https://pi.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://poe.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bhapi-ai-safety@bhapi.ai",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "isSelling": false,
        "isSharing": false,
        "isCollecting": true,
        "description": "Bhapi collects AI platform usage data (platform name, timestamps, safety classifications) to provide parents and guardians with safety monitoring. No conversation content is stored without explicit consent."
      }
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "scripts": ["background/service-worker.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://copilot.microsoft.com/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://grok.com/*",
        "https://x.com/i/grok*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://character.ai/*",
        "https://beta.character.ai/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://web.replika.com/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://pi.ai/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://poe.com/*"
      ],
      "js": ["content/monitor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*",
        "https://grok.com/*"
      ],
      "js": ["src/blocking.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Bhapi AI Safety Monitor",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
