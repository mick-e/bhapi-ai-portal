{
  "manifest_version": 3,
  "name": "Bhapi AI Safety Monitor",
  "version": "1.0.0",
  "description": "Monitor and protect your family's AI interactions",
  "permissions": ["activeTab", "storage", "alarms"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://copilot.microsoft.com/*",
        "*://claude.ai/*",
        "*://grok.com/*"
      ],
      "js": ["content/monitor.js"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
