# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://bhapi:bhapi_dev_password@localhost:5432/bhapi

# Redis (optional — app degrades gracefully without it; in-memory rate limiter used as fallback)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=dev-secret-key-change-in-production

# CORS — comma-separated origins (overrides defaults when set)
# CORS_ORIGINS=https://bhapi.ai,https://www.bhapi.ai

# Encryption — optional separate Fernet key; falls back to SECRET_KEY
# ENCRYPTION_KEY=your-encryption-key-here

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Session
SESSION_TIMEOUT_HOURS=24

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_OPEN=false

# Capture HMAC validation (disabled in dev/test)
CAPTURE_HMAC_ENABLED=false
# CAPTURE_HMAC_SECRET=your-hmac-secret

# Safety classifier mode: keyword_only, vertex_ai, auto
SAFETY_CLASSIFIER_MODE=keyword_only
# VERTEX_AI_MODEL=gemini-1.5-flash
# VERTEX_AI_LOCATION=us-central1

# OAuth SSO (register apps at each provider's developer console)
# OAUTH_REDIRECT_BASE_URL=http://localhost:8000
# OAUTH_GOOGLE_CLIENT_ID=...
# OAUTH_GOOGLE_CLIENT_SECRET=...
# OAUTH_MICROSOFT_CLIENT_ID=...
# OAUTH_MICROSOFT_CLIENT_SECRET=...
# OAUTH_APPLE_CLIENT_ID=...
# OAUTH_APPLE_CLIENT_SECRET=...
# OAUTH_APPLE_TEAM_ID=...
# OAUTH_APPLE_KEY_ID=...

# Stripe (production)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...

# Email (production)
# SENDGRID_API_KEY=SG....

# GCP (production — enables Cloud KMS encryption)
# GCP_PROJECT_ID=bhapi-ai-portal
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Stripe Family plan price IDs (School/Club use custom pricing via sales)
# STRIPE_PRICE_FAMILY_MONTHLY=price_...
# STRIPE_PRICE_FAMILY_ANNUAL=price_...

# LLM Provider APIs (for spend tracking)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Deepfake Detection (optional)
# DEEPFAKE_PROVIDER=hive
# DEEPFAKE_API_KEY=...

# Production E2E Tests
# PROD_BASE_URL=https://bhapi.ai
# PROD_API_KEY=bhapi_sk_...
