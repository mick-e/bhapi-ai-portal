{
  "cli": { "version": ">= 14.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "safety@bhapi.ai",
        "ascAppId": "SAFETY_ASC_APP_ID",
        "appleTeamId": "BHAPI_TEAM_ID",
        "backgroundLocationJustification": "Bhapi Safety uses background location to monitor geofences and alert parents when children arrive at or depart from designated safe zones."
      },
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "production",
        "releaseStatus": "inProgress",
        "rollout": 0.1
      }
    }
  }
}
