{
  "expo": {
    "name": "Bhapi Safety",
    "slug": "bhapi-safety",
    "version": "4.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "bhapi-safety",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D9488"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bhapi.safety",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Bhapi Safety needs camera access to scan QR codes for device pairing.",
        "NSPhotoLibraryUsageDescription": "Bhapi Safety needs photo library access to save safety reports.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Bhapi Safety uses location to help parents verify their child's device is at expected locations such as school or home.",
        "NSLocationWhenInUseUsageDescription": "Bhapi Safety uses location to help parents verify their child's device is at expected locations such as school or home.",
        "NSLocationAlwaysUsageDescription": "Bhapi Safety uses background location so parents can receive alerts when their child's device leaves or arrives at safe zones.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSPrivacyAccessedAPITypes": [],
        "NSUserTrackingUsageDescription": "Bhapi Safety does not track users for advertising purposes.",
        "coppaDirectedToChildren": false
      },
      "privacyManifest": {
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeLocation",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeContactInfo",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeUserID",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D9488"
      },
      "package": "com.bhapi.safety",
      "versionCode": 4,
      "permissions": [
        "CAMERA",
        "POST_NOTIFICATIONS",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "intentFilters": [],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0D9488"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Bhapi Safety needs camera access to scan QR codes for device pairing."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Bhapi Safety uses location to help parents verify their child's device is at expected locations such as school or home.",
          "locationAlwaysPermission": "Bhapi Safety uses background location so parents can receive alerts when their child's device leaves or arrives at safe zones.",
          "locationWhenInUsePermission": "Bhapi Safety uses location to help parents verify their child's device is at expected locations such as school or home.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      },
      "apiUrl": "https://bhapi.ai/api/v1",
      "wsUrl": "wss://bhapi.ai/ws",
      "coppa": {
        "directedToChildren": false,
        "targetAudience": "parents",
        "ageGating": false,
        "declaration": "Bhapi Safety is a parent-facing monitoring application. It is not directed to children. Users must be 18 or older.",
        "complianceDate": "2026-04-22"
      }
    },
    "owner": "bhapi",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/REPLACE_WITH_EAS_PROJECT_ID"
    }
  }
}
