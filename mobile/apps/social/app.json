{
  "expo": {
    "name": "Bhapi Social",
    "slug": "bhapi-social",
    "version": "4.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "bhapi-social",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bhapi.social",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Bhapi Social needs camera access to take photos for posts and your profile picture.",
        "NSPhotoLibraryUsageDescription": "Bhapi Social needs photo library access to share images in posts and set your profile picture.",
        "NSPhotoLibraryAddUsageDescription": "Bhapi Social needs permission to save images to your photo library.",
        "NSMicrophoneUsageDescription": "Bhapi Social needs microphone access for voice messages.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "Bhapi Social does not track users for advertising purposes.",
        "coppaDirectedToChildren": true
      },
      "privacyManifest": {
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhotosOrVideos",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeContactInfo",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeUserID",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeUserContent",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ],
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.bhapi.social",
      "versionCode": 4,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "POST_NOTIFICATIONS",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE"
      ],
      "contentRating": "EVERYONE_10_PLUS",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B35"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Bhapi Social needs camera access to take photos for posts and your profile picture."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Bhapi Social needs photo library access to share images in posts and set your profile picture.",
          "savePhotosPermission": "Bhapi Social needs permission to save images to your photo library."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Bhapi Social needs photo library access to share images in posts."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      },
      "apiUrl": "https://bhapi.ai/api/v1",
      "wsUrl": "wss://bhapi.ai/ws",
      "coppa": {
        "directedToChildren": true,
        "targetAudience": "mixed",
        "ageGating": true,
        "minimumAge": 5,
        "parentalConsentRequired": true,
        "declaration": "Bhapi Social is directed to children and has a mixed audience (children and parents). Verifiable parental consent is required before children can use the app. Content is moderated and age-appropriate.",
        "complianceDate": "2026-04-22",
        "contentRating": "Everyone 10+"
      }
    },
    "owner": "bhapi",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/REPLACE_WITH_EAS_PROJECT_ID"
    }
  }
}
